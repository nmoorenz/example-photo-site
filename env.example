# Copy this to .env — never commit .env to git

# AWS credentials (output from: terraform output -json)
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=ap-southeast-2

# Your S3 bucket name (must match terraform.tfvars)
S3_BUCKET=your-photos-bucket-name

# Path to your local photos folder
# Each subfolder = one album
LOCAL_PHOTOS_DIR=./photos

# Base URL for photos and manifest — your CloudFront domain
CLOUDFRONT_URL=https://cdn.example.com

# ── Netlify (set these in Netlify dashboard, not here) ──────────────────────
# PHOTO_SITE_PASSWORD=your-secret-password
# S3_MANIFEST_URL=https://cdn.example.com/manifest.json
